{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pitstop://schemas/decision_event.v1",
  "title": "Pitstop Decision Event v1 (Canonical Receipt)",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "receipt_id",
    "ts_utc",
    "execution_id",
    "attempt_id",
    "tool_id",
    "operation",
    "endpoint_norm",
    "budget",
    "outcome",
    "cost",
    "decision"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "decision_event.v1"
    },

    "receipt_id": { "type": "string", "minLength": 1 },
    "ts_utc": { "type": "string", "minLength": 1 },
    "execution_id": { "type": "string", "minLength": 1 },
    "attempt_id": { "type": "integer", "minimum": 1 },

    "attempt": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "prior_attempts"],
      "properties": {
        "kind": { "type": "string", "enum": ["primary", "retry", "fallback"] },
        "prior_attempts": { "type": "integer", "minimum": 0 }
      }
    },

    "intent": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "operation_class", "purpose", "is_destructive"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string" },
        "operation_class": { "type": "string", "minLength": 1 },
        "is_destructive": { "type": "boolean" }
      }
    },

    "tool_id": { "type": "string", "minLength": 1 },
    "operation": { "type": "string", "minLength": 1 },
    "endpoint_norm": { "type": "string", "minLength": 1 },

    "provider_id": { "type": "string", "minLength": 1 },
    "model_id": { "type": "string", "minLength": 1 },

    "scope": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model_key": { "type": "string", "minLength": 1 },
        "provider_key": { "type": "string", "minLength": 1 },
        "credential_key": { "type": "string", "minLength": 1 }
      }
    },

    "context": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "env_bucket": { "type": "string" },
        "region_bucket": { "type": "string" },
        "concurrency_bucket": { "type": "string" },
        "tenant_tier": { "type": "string" }
      }
    },

    "budget": {
      "type": "object",
      "additionalProperties": true,
      "required": ["deadline_ms", "max_elapsed_ms", "retry_budget"],
      "properties": {
        "deadline_ms": { "type": "integer", "minimum": 0 },
        "max_elapsed_ms": { "type": "integer", "minimum": 0 },
        "retry_budget": { "type": "integer", "minimum": 0 },
        "token_budget": { "type": ["integer", "null"], "minimum": 0 }
      }
    },

    "policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": { "type": "string", "enum": ["shadow", "enforce"] },
        "fail_behavior": { "type": "string", "enum": ["fail_open", "fail_closed"] },
        "max_attempts": { "type": "integer", "minimum": 0 },
        "allow_destructive": { "type": "boolean" },
        "concurrency_cap": { "type": ["integer", "null"], "minimum": 0 },
        "cooldown": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "backoff": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "strategy": { "type": "string" },
            "jitter": { "type": "boolean" },
            "respect_retry_after": { "type": "boolean" }
          }
        }
      }
    },

    "outcome": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["ok", "fail"] },
        "error_class": {
          "type": ["string", "null"],
          "enum": [
            "rate_limit_429",
            "rate_limit_secondary",
            "timeout_deadline",
            "auth_401",
            "auth_403",
            "billing_402",
            "server_5xx",
            "invalid_4xx",
            "network",
            "unknown",
            null
          ]
        },
        "http_status": { "type": ["integer", "null"], "minimum": 100, "maximum": 599 },
        "retry_after_ms": { "type": ["integer", "null"], "minimum": 0 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "fail" } },
            "required": ["status"]
          },
          "then": { "required": ["error_class"] }
        }
      ]
    },

    "cost": {
      "type": "object",
      "additionalProperties": true,
      "required": ["latency_ms"],
      "properties": {
        "latency_ms": { "type": "number", "minimum": 0 },
        "backoff_ms": { "type": ["number", "null"], "minimum": 0 },
        "tokens_est": { "type": ["number", "null"], "minimum": 0 }
      }
    },

    "decision": {
      "type": "object",
      "additionalProperties": true,
      "required": ["action", "reason_code", "mode"],
      "properties": {
        "action": {
          "type": "string",
          "enum": ["allow", "allow_shadow", "retry", "fallback", "cooldown", "block"]
        },
        "reason_code": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["shadow", "enforce"] }
      }
    },

    "evidence": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "rate_limit_type": { "type": "string", "enum": ["primary", "secondary"] },
        "classification_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "destructive_detected": { "type": "boolean" }
      }
    }
  }
}