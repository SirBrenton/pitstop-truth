{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pitstop-truth receipt",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "created_at",
    "source",
    "hazard",
    "constraints",
    "knobs",
    "verification"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["receipt.v0"] },
    "id": { "type": "string", "pattern": "^PT-\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]{8,}$" },
    "created_at": { "type": "string", "format": "date-time" },

    "source": {
      "type": "object",
      "required": ["url", "kind"],
      "properties": {
        "url": { "type": "string" },
        "kind": { "type": "string", "enum": ["github_issue", "github_pr", "log", "incident_postmortem", "other"] },
        "repo": { "type": "string" },
        "issue_or_pr": { "type": "integer" }
      },
      "additionalProperties": true
    },

    "hazard": {
      "type": "object",
      "required": ["class", "summary", "signals"],
      "properties": {
        "class": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary": { "type": "string" },
        "signals": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

        "mitigation_signature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hazards": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "knobs": { "type": "array", "items": { "type": "string" } },
        "anti_patterns": { "type": "array", "items": { "type": "string" } }
      }
    },

    "routing_impact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_action": {
          "type": "string",
          "enum": [
            "cooldown_and_route_away",
            "retry_with_budget",
            "fail_fast",
            "defer_and_probe",
            "quarantine_provider"
          ]
        },
        "cooldown_source": {
          "type": "string",
          "enum": ["retry_after_header", "fixed_seconds", "server_hint", "none"]
        },
        "cooldown_scope_key": { "type": "string" },

        "during_cooldown": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "make_http_call": { "type": "boolean" },
            "eligible_for_routing": { "type": "boolean" },
            "emit_decision_event": { "type": "boolean" }
          }
        },

        "after_cooldown": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "probe_strategy": { "type": "string", "enum": ["single_flight", "limited_qps", "none"] },
            "max_probe_qps": { "type": "number", "minimum": 0 }
          }
        }
      }
    },

    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },

    "knobs": {
      "type": "array",
      "items": { "type": "string" }
    },

    "verification": {
      "type": "array",
      "items": { "type": "string" }
    },

    "notes": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
