{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pitstop-truth receipt",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "created_at",
    "source",
    "hazard",
    "constraints",
    "knobs",
    "verification"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["receipt.v0"] },
    "id": { "type": "string", "pattern": "^PT-\\d{4}-\\d{2}-\\d{2}-[a-z0-9-]{8,}$" },
    "created_at": { "type": "string", "format": "date-time" },

    "source": {
      "type": "object",
      "required": ["url", "kind"],
      "properties": {
        "url": { "type": "string" },
        "kind": { "type": "string", "enum": ["github_issue", "github_pr", "log", "incident_postmortem", "other"] },
        "repo": { "type": "string" },
        "issue_or_pr": { "type": "integer" }
      },
      "additionalProperties": true
    },

    "hazard": {
      "type": "object",
      "required": ["class", "summary", "signals"],
      "properties": {
        "class": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summary": { "type": "string" },
        "signals": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },

    "mitigation_signature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hazards": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "knobs": { "type": "array", "items": { "type": "string" } },
        "anti_patterns": { "type": "array", "items": { "type": "string" } }
      }
    },

    "routing_impact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "default_action": {
          "type": "string",
          "enum": [
            "cooldown_and_route_away",
            "retry_with_budget",
            "fail_fast",
            "defer_and_probe",
            "quarantine_provider"
          ]
        },
        "cooldown_source": {
          "type": "string",
          "enum": ["retry_after_header", "fixed_seconds", "server_hint", "none"]
        },
        "cooldown_scope_key": { "type": "string" },

        "during_cooldown": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "make_http_call": { "type": "boolean" },
            "eligible_for_routing": { "type": "boolean" },
            "emit_decision_event": { "type": "boolean" }
          }
        },

        "after_cooldown": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "probe_strategy": { "type": "string", "enum": ["single_flight", "limited_qps", "none"] },
            "max_probe_qps": { "type": "number", "minimum": 0 }
          }
        }
      }
    },

    "impact": {
      "type": "object",
      "description": "Operational and economic consequences activated by this receipt. Distinct from hazard, which describes what failed.",
      "additionalProperties": false,
      "properties": {
        "cost_channels": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "api_spend",
              "latency",
              "workflow_failure",
              "support_escalation",
              "quota_burn",
              "retry_amplification",
              "operator_debug_time",
              "customer_visible_failure",
              "incident_risk"
            ]
          }
        },
        "operator_impact": {
          "type": "string",
          "description": "What a Level 3/4 operator observes — the operational consequence, not the technical failure."
        },
        "business_consequence": {
          "type": "string",
          "description": "Economic or business-level consequence for the buyer or operator."
        }
      }
    },

    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },

    "knobs": {
      "type": "array",
      "items": { "type": "string" }
    },

    "verification": {
      "type": "array",
      "items": { "type": "string" }
    },

    "notes": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    
    "signal_failure_type": {
      "type": "string",
      "enum": ["missing", "ignored", "hidden", "overridden"],
      "description": "Where in the signal chain the failure occurred. missing=never emitted, ignored=present but unused, hidden=suppressed by layer, overridden=nullified by transport or timeout"
    },

    "signal_topology": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "signal_origin": {
          "type": "string",
          "enum": [
            "provider",
            "transport",
            "runtime",
            "classifier",
            "orchestrator",
            "ui",
            "unknown"
          ]
        },
        "failure_layer": {
          "type": "string",
          "enum": [
            "transport",
            "runtime",
            "classifier",
            "orchestrator",
            "ui",
            "unknown"
          ]
        },
        "decision_layer": {
          "type": "string",
          "enum": [
            "retry_logic",
            "router",
            "failover",
            "agent",
            "user_interface",
            "unknown"
          ]
        },
        "signal_failure_type": {
          "type": "string",
          "enum": [
            "missing",
            "ignored",
            "hidden",
            "overridden"
          ]
        },
        "downstream_effect": {
          "type": "string",
          "enum": [
            "retry_loop",
            "cost_burn",
            "blocked_failover",
            "silent_degradation",
            "workflow_stall",
            "false_terminal",
            "false_unavailable",
            "unknown"
          ]
        }
      },
      "required": [
        "signal_origin",
        "failure_layer",
        "decision_layer",
        "signal_failure_type",
        "downstream_effect"
      ]
    }
  },
  "additionalProperties": false
}
